APP_NAME=calixy
APP_ENV=local
APP_KEY=base64:QCDAjqAcmAAg7VTakrvgUjizcQpYJWDCYZ/fu3/JXXI=
APP_DEBUG=true
APP_URL=http://calixy.test
APP_TIMEZONE=America/New_York
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

UNIFIED_APPOINTMENTS_DATABASE_LIBRARY_PATH="src/Database/Unified Databases"
UNIFIED_APPOINTMENTS_EDITION=startup
UNIFIED_APPOINTMENTS_AUTO_BOOTSTRAP=true
UNIFIED_APPOINTMENTS_STARTUP_DATABASE="database/unified-appointments.sqlite"
UNIFIED_APPOINTMENTS_TABLE_PREFIX=ua_
UNIFIED_APPOINTMENTS_TIMEZONE=America/New_York
UNIFIED_APPOINTMENTS_ROUTES_ENABLED=true
UNIFIED_APPOINTMENTS_ROUTE_PREFIX=unified-appointments
UNIFIED_APPOINTMENTS_THEME=atlantic
UNIFIED_APPOINTMENTS_THEME_QUERY_PARAMETER=theme
UNIFIED_APPOINTMENTS_ALLOW_THEME_SWITCHER=true

CALIXY_APPLICATION_NAME="Calixy"
CALIXY_VERSION="1.5.0"
CALIXY_DONATIONWARE_URL=""
