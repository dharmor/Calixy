APP_NAME="Calixy"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=America/New_York

# Laravel values when running this repo directly.
UNIFIED_APPOINTMENTS_DATABASE_LIBRARY_PATH="src/Database/Unified Databases"
UNIFIED_APPOINTMENTS_EDITION=startup
UNIFIED_APPOINTMENTS_AUTO_BOOTSTRAP=true
UNIFIED_APPOINTMENTS_STARTUP_DATABASE="database/unified-appointments.sqlite"
UNIFIED_APPOINTMENTS_TABLE_PREFIX=ua_
UNIFIED_APPOINTMENTS_TIMEZONE=America/New_York
UNIFIED_APPOINTMENTS_ROUTES_ENABLED=true
UNIFIED_APPOINTMENTS_ROUTE_PREFIX=unified-appointments
UNIFIED_APPOINTMENTS_THEME=atlantic
UNIFIED_APPOINTMENTS_THEME_QUERY_PARAMETER=theme
UNIFIED_APPOINTMENTS_ALLOW_THEME_SWITCHER=true

# Active MySQL connection for Calixy. Blank these or set driver to sqlite to switch back.
UNIFIED_APPOINTMENTS_DRIVER=postgreSQL
UNIFIED_APPOINTMENTS_HOST=127.0.0.1
UNIFIED_APPOINTMENTS_PORT=5432
UNIFIED_APPOINTMENTS_DATABASE=calixy
UNIFIED_APPOINTMENTS_USERNAME=calixy_user
UNIFIED_APPOINTMENTS_PASSWORD=ChangeMeNow!123

CALIXY_APPLICATION_NAME="Calixy"
CALIXY_VERSION="1.5.0"
CALIXY_DONATIONWARE_URL="https://github.com/sponsors"
