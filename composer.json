{
    "name": "calixy/unified-appointments",
    "description": "Appointment and availability engine for Laravel apps backed by the Unified Databases connection layer.",
    "type": "library",
    "license": "proprietary",
    "keywords": [
        "laravel",
        "appointments",
        "availability",
        "scheduling"
    ],
    "require": {
        "php": "^8.2",
        "ext-pdo": "*",
        "illuminate/console": "^11.0 || ^12.0 || ^13.0",
        "illuminate/contracts": "^11.0 || ^12.0 || ^13.0",
        "illuminate/http": "^11.0 || ^12.0 || ^13.0",
        "illuminate/routing": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "illuminate/validation": "^11.0 || ^12.0 || ^13.0",
        "illuminate/view": "^11.0 || ^12.0 || ^13.0"
    },
    "suggest": {},
    "autoload": {
        "psr-4": {
            "UnifiedAppointments\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "UnifiedAppointments\\Laravel\\UnifiedAppointmentsServiceProvider"
            ],
            "aliases": {
                "Calixy": "UnifiedAppointments\\Laravel\\Facades\\Calixy",
                "UnifiedAppointments": "UnifiedAppointments\\Laravel\\Facades\\UnifiedAppointments"
            }
        }
    }
}
